{
  "name": "lexi-gui",
  "version": "0.2.0",
  "private": true,
  "description": "Lexi GUI for interacting with multiple LLM providers via the CLI backend.",
  "bin": {
    "lexi-gui": "./bin/lexi-gui.js"
  },
  "main": "src/server/index.js",
  "scripts": {
    "dev": "node --watch src/server/index.js",
    "start": "node src/server/index.js",
    "test": "jest",
    "lint": "eslint src/",
    "format": "prettier --write src/ public/"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0"
  }
}
